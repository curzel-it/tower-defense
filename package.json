{
  "name": "sneakbit",
  "version": "1.8.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "npm run test:unit && npm run test:e2e",
    "test:unit": "node --test tests/*.test.js",
    "test:e2e": "node --test --test-timeout=120000 --test-concurrency=1 tests/e2e/*.test.mjs",
    "shots": "node tools/screenshot.mjs",
    "sprites": "node tools/exportSpriteSheets.mjs",
    "build": "node tools/build.mjs",
    "deploy": "node tools/deploy.mjs",
    "stream:deploy": "node tools/stream/deploy.mjs",
    "serve": "node tools/serve.mjs",
    "dev": "node tools/serve.mjs",
    "electron": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac --win --linux --x64",
    "steam": "python3 tools/steam_upload.py"
  },
  "build": {
    "appId": "it.curzel.sneakbit",
    "productName": "SneakBit",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**",
      "_site/**",
      "package.json"
    ],
    "asar": true,
    "mac": {
      "target": "dir",
      "category": "public.app-category.games"
    },
    "win": {
      "target": "dir"
    },
    "linux": {
      "target": "dir",
      "category": "Game"
    }
  },
  "devDependencies": {
    "electron": "^42.3.2",
    "electron-builder": "^26.8.1",
    "esbuild": "0.28.0",
    "ssh2": "1.17.0"
  }
}
